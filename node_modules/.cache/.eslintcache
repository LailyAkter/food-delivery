nimport Breadcrumb from '../Breadcrumb/Breadcrumb'\r\n\r\nexport default function Login() {\r\n  return (\r\n    <>\r\n        <Breadcrumb title=\"Login\" />\r\n        <section className=\"home-icon login-register bg-skeen\">\r\n            <div className=\"icon-default icon-skeen\">\r\n                <img src=\"images/scroll-arrow.png\" alt=\"\"/>\r\n            </div>\r\n            <div className=\"container\">\r\n                <div className=\"row\">\r\n                    <div className=\"col-md-8  col-sm-offset-2 col-sm-8 col-md-offset-2\">\r\n                        <div className=\"login-wrap form-common\">\r\n                            <div className=\"title text-center\">\r\n                                <h3 className=\"text-coffee\">Login</h3>\r\n                            </div>\r\n                            <form className=\"login-form\" method=\"post\" name=\"login\">\r\n                                <div className=\"row\">\r\n                                    <div className=\"col-md-12 col-sm-12 col-xs-12\">\r\n                                        <input type=\"text\" name=\"txt\" placeholder=\"Username or email address\" className=\"input-fields\"/>\r\n                                    </div>\r\n                                    <div className=\"col-md-12 col-sm-12 col-xs-12\">\r\n                                        <input type=\"password\" name=\"password\" placeholder=\"********\" className=\"input-fields\"/>\r\n                                    </div>\r\n                                    <div className=\"col-md-12 col-sm-12 col-xs-12\">\r\n                                        <div className=\"row\">\r\n                                            <div className=\"col-md-6 col-sm-6 col-xs-12\">\r\n                                                <label>\r\n                                                    <input type=\"checkbox\" name=\"chkbox\"/>Remember me</label>\r\n                                            </div>\r\n                                            <div className=\"col-md-6 col-sm-6 col-xs-12\">\r\n                                                <a href=\"#\" className=\"pull-right\">Lost your password</a>\r\n                                            </div>\r\n                                        </div>\r\n                                    </div>\r\n                                    <div className=\"col-md-12 col-sm-12 col-xs-12\">\r\n                                        <input type=\"submit\" name=\"submit\" value=\"LOGIN\" className=\"button-default button-default-submit\"/>\r\n                                    </div>\r\n                                </div>\r\n                            </form>\r\n                            <div className=\"divider-login\">\r\n                                <hr/>\r\n                                <span>Or</span>\r\n                            </div>\r\n                            <div className=\"row\">\r\n                                <div className=\"col-md-6 col-sm-12 col-xs-12\">\r\n                                    <a href=\"#\" className=\"facebook-btn btn-change button-default\"><i className=\"fa fa-facebook\"></i>Facebook Connect</a>\r\n                                </div>\r\n                                <div className=\"col-md-6 col-sm-12 col-xs-12\">\r\n                                    <a href=\"#\" className=\"tweeter-btn btn-change button-default\"><i className=\"fa fa-twitter\"></i>Twitter Connect</a>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>\r\n    </>\r\n  )\r\n}\r\n","G:\\react\\food-delivery\\src\\components\\Cart\\Cart.jsx",["186"],[],"import React from 'react'\r\nimport {Link} from 'react-router-dom'\r\nimport Breadcrumb from '../Breadcrumb/Breadcrumb'\r\nimport {useSelector,useDispatch} from 'react-redux';\r\nimport { cartActions } from \"../../store/shopping-cart/Cart.js\";\r\n\r\nexport default function Cart() {\r\n    const dispatch = useDispatch();\r\n    const cartProducts = useSelector((state)=>state.cart.cartItems);\r\n    const totalAmount = useSelector((state)=>state.cart.totalAmount)\r\n    const shipping_amount = Number(15);\r\n\r\n    const total = totalAmount + shipping_amount;\r\n\r\n    //  const incrementCart = () =>{\r\n    //     dispatch(cartActions.addItem())\r\n    // }\r\n\r\n  return (\r\n    <>\r\n        <Breadcrumb title=\"Cart\"/>\r\n        <section className=\"home-icon shop-cart bg-skeen\">\r\n            <div className=\"icon-default icon-skeen\">\r\n                <img src=\"images/scroll-arrow.png\" alt=\"\"/>\r\n            </div>\r\n            <div className=\"container\">\r\n                <div className=\"checkout-wrap wow fadeInDown\" data-wow-duration=\"1000ms\" data-wow-delay=\"300ms\">\r\n                    <ul className=\"checkout-bar\">\r\n                        <li className=\"active\">Shopping Cart</li>\r\n                        <li>Checkout</li>\r\n                        <li>Order Complete</li>\r\n                    </ul>\r\n                </div>\r\n                <div className=\"shop-cart-list wow fadeInDown\" data-wow-duration=\"1000ms\" data-wow-delay=\"300ms\">\r\n                    <table className=\"shop-cart-table\">\r\n                        <thead>\r\n                            <tr>\r\n                                <th>PRODUCT</th>\r\n                                <th>PRICE</th>\r\n                                <th>QUANTITY</th>\r\n                                <th>TOTAL</th>\r\n                            </tr>\r\n                        </thead>\r\n                        <tbody>\r\n                            {\r\n                                cartProducts.length === 0  ? <h3 className='text-center'>No item added to cart</h3> :\r\n                                (\r\n                                    cartProducts.map((product)=>{\r\n                                        return(\r\n                                            <tr>\r\n                                                <th>PRODUCT</th>\r\n                                                <td>\r\n                                                    <div className=\"product-cart\">\r\n                                                        <img style={{height:'98px',width:'98px'}} src={product.imageO1} alt={product.name}/>\r\n                                                    </div>\r\n                                                    <div className=\"product-cart-title\">\r\n                                                        <span>{product.name}</span>\r\n                                                        <br/>\r\n                                                        <span>1*{product.qty}</span>\r\n                                                    </div>\r\n                                                </td>\r\n                                                <th>PRICE</th>\r\n                                                <td>\r\n                                                    <strong>${product.price}</strong>\r\n                                                    {/* <del>$5400.00</del> */}\r\n                                                </td>\r\n                                                <th>QUANTITY</th>\r\n                                                <td>\r\n                                                    <div className=\"price-textbox\">\r\n                                                        <span className=\"minus-text\"><i onClick={()=>dispatch(cartActions.removeItem(product.id))} className=\"fa fa-minus\" aria-hidden=\"true\"></i></span>\r\n                                                        <input name=\"txt\" placeholder={product.qty} type=\"text\"/>\r\n                                                        <span className=\"plus-text\"><i onClick={()=>dispatch(cartActions.addItem(product))} className=\"fa fa-plus\" aria-hidden=\"true\"></i></span>\r\n                                                    </div>\r\n                                                </td>\r\n                                                <th>TOTAL</th>\r\n                                                <td>\r\n                                                    ${product.totalPrice}\r\n                                                </td>\r\n                                                <td className=\"shop-cart-close\"><i onClick={()=>dispatch(cartActions.deleteItem(product.id))} className=\"fa fa-times\" aria-hidden=\"true\"></i></td>\r\n                                            </tr>\r\n                                        )\r\n                                    })\r\n                                )\r\n                            }\r\n                            \r\n                        </tbody>\r\n                    </table>\r\n                    <div className=\"product-cart-detail\">\r\n                        <div className=\"cupon-part\">\r\n                            <input type=\"text\" name=\"txt\" placeholder=\"Cupon Code\"/>\r\n                        </div>\r\n                        <a href=\"#\" className=\"btn-medium btn-dark-coffee\">Apply Coupon</a>\r\n                    </div>\r\n                </div>\r\n                <div className=\"cart-total wow fadeInDown\" data-wow-duration=\"1000ms\" data-wow-delay=\"300ms\">\r\n                    <div className=\"cart-total-title\">\r\n                        <h5>CART TOTALS</h5>\r\n                    </div>\r\n                    <div className=\"product-cart-total\">\r\n                        <small>Total products</small>\r\n                        <span>${totalAmount}</span>\r\n                    </div>\r\n                    <div className=\"product-cart-total\">\r\n                        <small>Total shipping</small>\r\n                        <span>${shipping_amount}</span>\r\n                    </div>\r\n                    <div className=\"grand-total\">\r\n                        <h5>TOTAL <span>${total}</span></h5>\r\n                    </div>\r\n                    <div className=\"proceed-check\">\r\n                        <Link to=\"/checkout\" className=\"btn-primary-gold btn-medium\">PROCEED TO CHECKOUT</Link>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </section>\r\n    </>\r\n  )\r\n}\r\n","G:\\react\\food-delivery\\src\\components\\Checkout\\Checkout.jsx",["187","188"],[],"G:\\react\\food-delivery\\src\\components\\Contact\\Contact.jsx",["189"],[],"import React from 'react'\r\nimport Breadcrumb from '../Breadcrumb/Breadcrumb'\r\n\r\nexport default function Contact() {\r\n  return (\r\n        <>\r\n            <Breadcrumb title=\"Contact\"/>\r\n            <section className=\"default-section contact-part home-icon\">\r\n                <div className=\"icon-default\">\r\n                    <a href=\"#\"><img src=\"images/scroll-arrow.png\" alt=\"\"/></a>\r\n                </div>\r\n                <div className=\"container\">\r\n                    <div className=\"title text-center\">\r\n                        <h2 className=\"text-coffee\">Contact Us</h2>\r\n                        <h6 className=\"heade-xs\">We are a second-generation family business established in 1972</h6>\r\n                    </div>\r\n                    <div className=\"row\">\r\n                        <div className=\"col-md-4 col-sm-4 col-xs-12 wow fadeInDown\" data-wow-duration=\"1000ms\" data-wow-delay=\"300ms\">\r\n                            <div className=\"contact-blog-row\">\r\n                                <div className=\"contact-icon\">\r\n                                    <img src=\"images/location-icon.png\" alt=\"\"/>\r\n                                </div>\r\n                                <p>329 Queensberry Street, North Melbourne VIC 3051, Australia.</p>\r\n                            </div>\r\n                        </div>\r\n                        <div className=\"col-md-4 col-sm-4 col-xs-12 wow fadeInDown\" data-wow-duration=\"1000ms\" data-wow-delay=\"300ms\">\r\n                            <div className=\"contact-blog-row\">\r\n                                <div className=\"contact-icon\">\r\n                                    <img src=\"images/cell-icon.png\" alt=\"\"/>\r\n                                </div>\r\n                                <p><a href=\"tel:1234567890\">123 456 7890</a></p>\r\n                            </div>\r\n                        </div>\r\n                        <div className=\"col-md-4 col-sm-4 col-xs-12 wow fadeInDown\" data-wow-duration=\"1000ms\" data-wow-delay=\"300ms\">\r\n                            <div className=\"contact-blog-row\">\r\n                                <div className=\"contact-icon\">\r\n                                    <img src=\"images/mail-icon.png\" alt=\"\"/>\r\n                                </div>\r\n                                <p><a href=\"mailto:support@despina.com\">support@despina.com</a></p>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <div className=\"row\">\r\n                        <div className=\"col-md-8 col-sm-8 col-xs-12 wow fadeInDown\" data-wow-duration=\"1000ms\" data-wow-delay=\"300ms\">\r\n                            <h5 className=\"text-coffee\">Leave us a Message</h5>\r\n                            <p>Aenean massa diam, viverra vitae luctus sed, gravida eget est. Etiam nec ipsum porttitor, consequat libero eu, dignissim eros. Nulla auctor lacinia enim id mollis.</p>\r\n                            <form className=\"form\" method=\"post\" name=\"contact-form\">\r\n                                <div className=\"row\">\r\n                                    <div className=\"alert-container\"></div>\r\n                                    <div className=\"col-md-6 col-sm-6 col-xs-12\">\r\n                                        <label>First Name *</label>\r\n                                        <input name=\"first_name\" type=\"text\" required/>\r\n                                    </div>\r\n                                    <div className=\"col-md-6 col-sm-6 col-xs-12\">\r\n                                        <label>Last Name *</label>\r\n                                        <input name=\"last_name\" type=\"text\" required/>\r\n                                    </div>\r\n                                    <div className=\"col-md-6 col-sm-6 col-xs-12\">\r\n                                        <label>Email *</label>\r\n                                        <input name=\"email\" type=\"email\" required/>\r\n                                    </div>\r\n                                    <div className=\"col-md-6 col-sm-6 col-xs-12\">\r\n                                        <label>Subject *</label>\r\n                                        <input name=\"subject\" type=\"text\" required/>\r\n                                    </div>\r\n                                    <div className=\"col-md-12 col-sm-12 col-xs-12\">\r\n                                        <label>Your Message *</label>\r\n                                        <textarea name=\"message\" required></textarea>\r\n                                    </div>\r\n                                    <div className=\"col-md-12 col-sm-12 col-xs-12\">\r\n                                        <input name=\"submit\" value=\"SEND MESSAGE\" className=\"btn-black pull-right send_message\" type=\"submit\"/>\r\n                                    </div>\r\n                                </div>\r\n                            </form>\r\n                        </div>\r\n                        <div className=\"col-md-4 col-sm-4 col-xs-12 wow fadeInDown\" data-wow-duration=\"1000ms\" data-wow-delay=\"300ms\">\r\n                            <h5 className=\"text-coffee\">Opening Hours</h5>\r\n                            <ul className=\"time-list\">\r\n                                <li><span className=\"week-name\">Monday</span> <span>12-6 PM</span></li>\r\n                                <li><span className=\"week-name\">Tuesday</span> <span>12-6 PM</span></li>\r\n                                <li><span className=\"week-name\">Wednesday</span> <span>12-6 PM</span></li>\r\n                                <li><span className=\"week-name\">Thursday</span> <span>12-6 PM</span></li>\r\n                                <li><span className=\"week-name\">Friday</span> <span>12-6 PM</span></li>\r\n                                <li><span className=\"week-name\">Saturday</span> <span>12-6 PM</span></li>\r\n                                <li><span className=\"week-name\">Sunday</span> <span>Closed</span></li>\r\n                            </ul>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </section>\r\n        </>\r\n  )\r\n}\r\n","G:\\react\\food-delivery\\src\\components\\Error\\Error.jsx",[],[],"G:\\react\\food-delivery\\src\\components\\Data\\Data.js",[],[],"G:\\react\\food-delivery\\src\\components\\Home\\Home.jsx",["190","191","192","193","194","195","196","197","198","199","200","201","202","203","204","205","206","207","208","209","210","211","212","213","214","215","216","217","218","219","220","221","222","223","224","225","226","227","228","229","230","231","232","233","234","235","236","237","238","239","240","241","242","243","244","245","246","247","248","249","250","251","252","253","254","255","256","257","258","259","260","261","262","263","264","265","266","267","268","269","270"],[],"import React from 'react'\r\nimport myBanner from \"../../images/banner2.jpg\";\r\nimport dish_img from \"../../images/banner1.jpg\";\r\nimport testimonial_img from \"../../images/banner3.jpg\";\r